# ── Python artifacts ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tests & development ───────────────────────────────────────────────────────
tests/
*.test.py
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Secrets (never bake into image) ──────────────────────────────────────────
.env
.env.*
!.env.example

# ── Integrations (not needed at runtime) ─────────────────────────────────────
integrations/

# ── Docs ─────────────────────────────────────────────────────────────────────
*.md
LICENSE

# ── CI/CD ────────────────────────────────────────────────────────────────────
.github/
Makefile
docker-compose*.yml
