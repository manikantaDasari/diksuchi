# ─────────────────────────────────────────────────────────────────────────────
#  AI Router — Environment Variables
#
#  Copy this file:  cp .env.example .env
#  Then fill in the keys for the cloud providers you want to use.
#  Keys for disabled providers (config.yaml enabled: false) are ignored.
#
#  NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (required for cloud routing to GPT-4o / GPT-4o-mini) ──────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (optional — enable in config.yaml first) ───────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (optional — ultra-fast inference, enable in config.yaml) ────────────
# GROQ_API_KEY=gsk_...

# ── Google Gemini (optional) ──────────────────────────────────────────────────
# GOOGLE_API_KEY=AIza...

# ── Together AI (optional) ───────────────────────────────────────────────────
# TOGETHER_API_KEY=...

# ── Mistral (optional) ────────────────────────────────────────────────────────
# MISTRAL_API_KEY=...

# ── Router settings ───────────────────────────────────────────────────────────
# Override the port the router listens on (default: 8080)
# ROUTER_PORT=8080

# Override which Ollama model to pull on first run (default: llama3.2)
# OLLAMA_MODEL=qwen2.5-coder:7b

# Use a pre-built image from GHCR instead of building locally
# ROUTER_IMAGE=ghcr.io/your-username/ai-router:latest
