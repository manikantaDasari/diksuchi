# ─────────────────────────────────────────────────────────────────────────────
#  Diksuchi — Environment Variables
#
#  Copy this file:  cp .env.example .env
#  Then fill in the keys for the cloud providers you want to use.
#  Keys for disabled providers (config.yaml enabled: false) are ignored.
#
#  NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenRouter (one key → free + paid models from ALL providers) ─────────────
# Single key unlocks: Claude, GPT-5, Gemini, Grok, Llama, Mistral, DeepSeek…
# Free models (openrouter_free provider) work without a key.
# Paid models (openrouter_paid provider) need a key + credits on openrouter.ai.
# OPENROUTER_API_KEY=sk-or-v1-...

# ── Individual provider keys (only needed if NOT routing through OpenRouter) ──

# OpenAI — direct GPT-5 / o3-pro access (skip if using OPENROUTER_API_KEY)
# OPENAI_API_KEY=sk-...

# Anthropic — direct Claude access (skip if using OPENROUTER_API_KEY)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — direct Gemini access (skip if using OPENROUTER_API_KEY)
# GOOGLE_API_KEY=AIza...

# xAI — direct Grok access (skip if using OPENROUTER_API_KEY)
# XAI_API_KEY=xai-...

# ── Groq (ultra-fast inference — not on OpenRouter, always direct) ────────────
# GROQ_API_KEY=gsk_...

# ── Together AI (optional) ───────────────────────────────────────────────────
# TOGETHER_API_KEY=...

# ── Mistral (optional — direct access) ───────────────────────────────────────
# MISTRAL_API_KEY=...

# ── Router settings ───────────────────────────────────────────────────────────
# Override the port the router listens on (default: 8080)
# ROUTER_PORT=8080

# Override which Ollama model to pull on first run (default: llama3.2)
# OLLAMA_MODEL=qwen2.5-coder:7b

# Use a pre-built image from GHCR instead of building locally
# ROUTER_IMAGE=ghcr.io/your-username/diksuchi:latest
